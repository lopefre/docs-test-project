30 \u0432 \u0440\u0430\u043c\u043a\u0430\u0445 \u043c\u0430\u0441\u0442\u0435\u0440-\u043a\u043b\u0430\u0441\u0441\u0430 \u043f\u043e docs as code.</p>","tags":["portfolio","manual"]},{"location":"instruction/lopefre-instruction/#ios-android","title":"\u041d\u0430 \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d\u0435 (iOS \u0438 Android)","text":"<ol> <li> <p>\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u043d\u0443\u0436\u043d\u044b\u0439 \u0447\u0430\u0442 \u0438 \u043d\u0430\u043f\u0438\u0448\u0438\u0442\u0435 \u0442\u0435\u043a\u0441\u0442 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \u0432 \u043f\u043e\u043b\u0435 \u0432\u0432\u043e\u0434\u0430.</p> </li> <li> <p>\u0417\u0430\u0436\u043c\u0438\u0442\u0435 \u0438 \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0443 \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0438.</p> </li> <li> <p>\u0412 \u043f\u043e\u044f\u0432\u0438\u0432\u0448\u0435\u043c\u0441\u044f \u043c\u0435\u043d\u044e \u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u043f\u0443\u043d\u043a\u0442 \u041e\u0442\u043f\u0440\u0430\u0432\u0438\u0442\u044c \u043f\u043e\u0437\u0436\u0435.</p> </li> <li> <p>\u0423\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0435 \u043d\u0443\u0436\u043d\u0443\u044e \u0434\u0430\u0442\u0443 \u0438 \u0432\u0440\u0435\u043c\u044f.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430 \u0441\u0438\u043d\u044e\u044e \u043a\u043d\u043e\u043f\u043a\u0443 \u0432\u043d\u0438\u0437\u0443 \u0434\u043b\u044f \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043d\u0438\u044f \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0438.</p> </li> </ol>","tags":["portfolio","manual"]},{"location":"instruction/lopefre-instruction/#telegram-desktop-macos","title":"\u041d\u0430 \u043a\u043e\u043c\u043f\u044c\u044e\u0442\u0435\u0440\u0435 (Telegram Desktop \u0438 macOS)","text":"<ol> <li> <p>\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u043d\u0443\u0436\u043d\u044b\u0439 \u0447\u0430\u0442 \u0438 \u043d\u0430\u043f\u0438\u0448\u0438\u0442\u0435 \u0442\u0435\u043a\u0441\u0442 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \u0432 \u043f\u043e\u043b\u0435 \u0432\u0432\u043e\u0434\u0430.</p> </li> <li> <p>\u041a\u043b\u0438\u043a\u043d\u0438\u0442\u0435 \u043f\u0440\u0430\u0432\u043e\u0439 \u043a\u043d\u043e\u043f\u043a\u043e\u0439 \u043c\u044b\u0448\u0438 \u043f\u043e \u0438\u043a\u043e\u043d\u043a\u0435 \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0438.</p> </li> <li> <p>\u0412 \u043f\u043e\u044f\u0432\u0438\u0432\u0448\u0435\u043c\u0441\u044f \u043c\u0435\u043d\u044e \u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u043f\u0443\u043d\u043a\u0442 \u041e\u0442\u043f\u0440\u0430\u0432\u0438\u0442\u044c \u043f\u043e\u0437\u0436\u0435.</p> </li> <li> <p>\u0423\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u0435 \u043d\u0443\u0436\u043d\u0443\u044e \u0434\u0430\u0442\u0443 \u0438 \u0432\u0440\u0435\u043c\u044f.</p> </li> <li> <p>\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u0417\u0430\u043f\u043b\u0430\u043d\u0438\u0440\u043e\u0432\u0430\u0442\u044c.</p> </li> </ol>","tags":["portfolio","manual"]},{"location":"instruction/lopefre-instruction/#_1","title":"\u041a\u0430\u043a \u043f\u043e\u0441\u043c\u043e\u0442\u0440\u0435\u0442\u044c \u0438\u043b\u0438 \u0443\u0434\u0430\u043b\u0438\u0442\u044c \u043e\u0442\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0435 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f","text":"<p>\u0412 \u0447\u0430\u0442\u0435, \u0433\u0434\u0435 \u0432\u044b \u0437\u0430\u043f\u043b\u0430\u043d\u0438\u0440\u043e\u0432\u0430\u043b\u0438 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0435, \u043f\u043e\u044f\u0432\u0438\u0442\u0441\u044f \u0438\u043a\u043e\u043d\u043a\u0430 \u043a\u0430\u043b\u0435\u043d\u0434\u0430\u0440\u044f. \u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043d\u0430 \u043d\u0435\u0435, \u0447\u0442\u043e\u0431\u044b \u043e\u0442\u043a\u0440\u044b\u0442\u044c \u0441\u043f\u0438\u0441\u043e\u043a \u043e\u0442\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0445 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0439, \u043e\u0442\u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0438\u0445, \u0438\u0437\u043c\u0435\u043d\u0438\u0442\u044c \u0432\u0440\u0435\u043c\u044f \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0438 \u0438\u043b\u0438 \u0443\u0434\u0430\u043b\u0438\u0442\u044c. </p> <p>\u041f\u0440\u0438\u043c\u0435\u0447\u0430\u043d\u0438\u0435: \u042d\u0442\u0430 \u0444\u0443\u043d\u043a\u0446\u0438\u044f \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u0432 \u043b\u0438\u0447\u043d\u044b\u0445 \u0447\u0430\u0442\u0430\u0445, \u0433\u0440\u0443\u043f\u043f\u0430\u0445 \u0438 \u043a\u0430\u043d\u0430\u043b\u0430\u0445.</p>","tags":["portfolio","manual"]},{"location":"readme/","title":"Readme","text":"<p>\u0417\u0434\u0435\u0441\u044c \u0431\u0443\u0434\u0443\u0442 \u043f\u0440\u0438\u043c\u0435\u0440\u044b Readme.</p>"},{"location":"readme/Autodocs/","title":"Autodocs","text":"","tags":["portfolio","readme"]},{"location":"readme/Autodocs/#autodocs","title":"Autodocs","text":"<p>Autodocs is a Python-based tool that automates documentation generation for licensing game products. It was created to simplify daily manual work for technical writers who don\u2019t have programming skills.</p>","tags":["portfolio","readme"]},{"location":"readme/Autodocs/#what-it-does","title":"What it does","text":"<ul> <li>Collects data from predefined sources  </li> <li>Generates structured Word documents using templates  </li> <li>Formats content consistently (headings, styles, layout)  </li> <li>Reduces time spent on routine documentation tasks from hours to minutes  </li> </ul>","tags":["portfolio","readme"]},{"location":"readme/Autodocs/#who-it-is-for","title":"Who it is for","text":"<ul> <li>Technical writers  </li> <li>Localization specialists  </li> <li>Documentation teams working with repetitive document structures  </li> </ul>","tags":["portfolio","readme"]},{"location":"readme/Autodocs/#key-features","title":"Key features","text":"<ul> <li>Simple usage: run one script to generate a ready-to-use document  </li> <li>No programming knowledge required  </li> <li>Error handling and basic troubleshooting included  </li> <li>Easily adaptable for new document templates  </li> </ul>","tags":["portfolio","readme"]},{"location":"readme/Autodocs/#documentation","title":"Documentation","text":"<p>Full documentation (in Russian): https://lopefre.github.io/Documentation/</p> <p>It includes: - Installation guide - Quick start - Usage scenarios - Formatting rules - Troubleshooting &amp; FAQ  </p>","tags":["portfolio","readme"]},{"location":"readme/Autodocs/#disclaimer","title":"\u26a0\ufe0f Disclaimer","text":"<p>This project was developed as an internal automation tool and is provided here for demonstration purposes only.</p>","tags":["portfolio","readme"]}]}